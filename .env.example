# Elsewhere Telephone Co. — bridge server environment
# Copy to .env at repo root. Run everything from repo root so Bun picks it up.

# --- OpenAI ---
# Project-scoped key from the "elsewhere" OpenAI project.
# The project MUST have a hard $25/mo budget cap set in the dashboard (CLAUDE.md rule).
OPENAI_API_KEY=sk-proj-...
# gpt-realtime-mini first; upgrade to gpt-realtime-2 (low reasoning effort) only if persona quality lags.
OPENAI_REALTIME_MODEL=gpt-realtime-mini
# Transcription model for caller-side speech (transcription events are always on).
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# --- Twilio ---
# Console -> Account Info. Used for signature validation + number management scripts.
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...

# --- Persona routing ---
# Map called numbers (E.164) to persona ids. Number A = devil-direct, Number B = operator.
# Example: PERSONA_NUMBER_MAP=+15055551234=devil,+15055555678=operator
PERSONA_NUMBER_MAP=
# Fallback when the called number isn't in the map (local dev, first number).
DEFAULT_PERSONA=devil

# --- Supabase (call logging) ---
# NEW key system only (sb_publishable_/sb_secret_): legacy anon/service_role
# JWT keys are deprecated and will be disabled by Supabase — do not use them.
# Secret key: Dashboard -> Project Settings -> API Keys -> secret key (server-side only).
# Leave empty to run without logging (local dev before Supabase exists).
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Dual-channel Twilio call recording (caller/persona split) for analysis.
# ON for the seed phase (internal-QA use only); disclosure is in-character in
# the Operator's cold-open once the switchboard ships. See env.ts + tracker A.
RECORD_CALLS=true

# F7: transcripts always go to Supabase; this only gates the stdout COPY, off by
# default so Railway logs aren't a shadow transcript corpus. On to debug locally.
LOG_TRANSCRIPTS=false

# --- Security / abuse backstops (F5, F33) ---
# X-Twilio-Signature + /media-stream token validation use TWILIO_AUTH_TOKEN above.
# Set to false ONLY to debug a signature mismatch on a live line.
TWILIO_VALIDATE=true
# Runaway/spend circuit breakers (in-memory, reset on restart). Generous defaults.
MAX_CONCURRENT_CALLS=8
MAX_CALLS_PER_DAY=100
MAX_CALLS_PER_CALLER=4
CALLER_WINDOW_MS=900000

# --- Server-VAD tuning (optional; background-chatter sensitivity) ---
# Unset = OpenAI defaults (no change). Raise threshold toward 1 to ignore more
# background speech. Tune empirically against real calls — see the tracker item.
VAD_THRESHOLD=
VAD_SILENCE_MS=
VAD_PREFIX_MS=

# --- Server ---
# Railway injects PORT. Locally defaults to 8080.
PORT=8080
# Public hostname for the TwiML <Stream> wss URL, e.g. elsewhere-bridge.up.railway.app
# If empty, the bridge derives it from the incoming request's Host header.
PUBLIC_HOST=
