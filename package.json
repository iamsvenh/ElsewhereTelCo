{
  "name": "elsewhere-telco",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --watch apps/bridge/src/index.ts",
    "start": "bun run apps/bridge/src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun run test:unit && bun run test:integration",
    "test:unit": "bun test tests/unit/",
    "test:integration": "bun test tests/integration/",
    "check": "bun run typecheck && bun run test"
  },
  "devDependencies": {
    "@elsewhere/personas": "workspace:*",
    "@types/bun": "^1.2.0",
    "playwright": "^1.61.1",
    "typescript": "^5.6.0"
  }
}
